{% doc %}
  @prompt
    Create a compact "As Seen On" homepage section for a Shopify drag brand called Ester Flonaze. This must be IDENTICAL in design to the existing section above it, just with exactly 7 logo slots.
    
    COPY (USE EXACTLY):
    - Small top text: "Granny's Been Around" — white, Playfair Display Bold, subtle gold glow/text-shadow (#D4AF37)
    - Below that: "AS SEEN ON" — purple (#C15CCF), Raleway or Montserrat, letter spacing 0.1em, smaller than headline
    
    BACKGROUND:
    - Deep purple gradient: #1A1A2E → #2a1f3d
    - Very subtle sparkle/glow texture overlay (low opacity gold/purple CSS radial gradients)
    - No white or flat backgrounds
    
    LOGO MARQUEE:
    - EXACTLY 7 logo image picker blocks in the schema — hard limit, no more no less
    - Horizontal infinite auto-scrolling marquee (CSS animation, seamless loop)
    - All logos same consistent height, evenly spaced
    - Default: grayscale, 75% opacity
    - Hover: pause animation, full color, slight brightness increase
    - Slow, smooth scroll speed
    
    GOLD DIVIDER:
    - Thin gold line (#D4AF37) above the logo row, subtle glow
    
    LAYOUT:
    - Compact vertical padding — tight and purposeful, not sprawling
    - Everything centered
    - "Granny's Been Around" on top, "AS SEEN ON" below, then gold divider, then scrolling logos
    
    MOBILE: Marquee scrolls smoothly, logos readable
    
    VIBE: Drag glam meets media credibility. Dawn-compatible Shopify section.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Raleway:wght@400;600&display=swap');

  .ai-as-seen-on-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(180deg, #1A1A2E 0%, #2a1f3d 100%);
    position: relative;
    overflow: hidden;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-as-seen-on-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
      radial-gradient(circle at 20% 30%, rgba(212, 175, 55, 0.05) 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(193, 92, 207, 0.05) 0%, transparent 50%),
      radial-gradient(circle at 50% 50%, rgba(212, 175, 55, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }

  .ai-as-seen-on-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }

  .ai-as-seen-on-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-as-seen-on-granny-text-{{ ai_gen_id }} {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: {{ block.settings.granny_font_size }}px;
    color: #FFFFFF;
    text-shadow: 0 0 20px rgba(212, 175, 55, 0.6), 0 0 40px rgba(212, 175, 55, 0.3);
    margin: 0 0 8px 0;
    line-height: 1.2;
  }

  .ai-as-seen-on-title-{{ ai_gen_id }} {
    font-family: 'Raleway', sans-serif;
    font-weight: 600;
    font-size: {{ block.settings.title_font_size }}px;
    color: #C15CCF;
    letter-spacing: 0.1em;
    margin: 0;
    text-transform: uppercase;
  }

  .ai-as-seen-on-divider-{{ ai_gen_id }} {
    width: 100%;
    height: 1px;
    background: #D4AF37;
    box-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
    margin: 0 0 {{ block.settings.divider_spacing }}px 0;
  }

  .ai-as-seen-on-marquee-wrapper-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .ai-as-seen-on-marquee-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.logo_spacing }}px;
    animation: ai-as-seen-on-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-as-seen-on-marquee-{{ ai_gen_id }}:hover {
    animation-play-state: paused;
  }

  .ai-as-seen-on-logo-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-as-seen-on-logo-item-{{ ai_gen_id }} img {
    height: 100%;
    width: auto;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.75;
    transition: all 0.3s ease;
  }

  .ai-as-seen-on-marquee-{{ ai_gen_id }}:hover .ai-as-seen-on-logo-item-{{ ai_gen_id }} img {
    filter: grayscale(0%);
    opacity: 1;
    filter: brightness(1.1);
  }

  .ai-as-seen-on-logo-placeholder-{{ ai_gen_id }} {
    height: 100%;
    width: 120px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.3);
    text-align: center;
    padding: 10px;
  }

  @keyframes ai-as-seen-on-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-as-seen-on-granny-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.granny_font_size | times: 0.7 }}px;
    }

    .ai-as-seen-on-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.8 }}px;
    }

    .ai-as-seen-on-logo-item-{{ ai_gen_id }} {
      height: {{ block.settings.logo_height | times: 0.7 }}px;
    }
  }
{% endstyle %}

<as-seen-on-{{ ai_gen_id }} class="ai-as-seen-on-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-as-seen-on-container-{{ ai_gen_id }}">
    <div class="ai-as-seen-on-header-{{ ai_gen_id }}">
      {% if block.settings.granny_text != blank %}
        <div class="ai-as-seen-on-granny-text-{{ ai_gen_id }}">{{ block.settings.granny_text }}</div>
      {% endif %}
      {% if block.settings.title_text != blank %}
        <h2 class="ai-as-seen-on-title-{{ ai_gen_id }}">{{ block.settings.title_text }}</h2>
      {% endif %}
    </div>

    <div class="ai-as-seen-on-divider-{{ ai_gen_id }}"></div>

    <div class="ai-as-seen-on-marquee-wrapper-{{ ai_gen_id }}">
      <div class="ai-as-seen-on-marquee-{{ ai_gen_id }}">
        {% for i in (1..7) %}
          {% assign logo_key = 'logo_' | append: i %}
          {% assign logo = block.settings[logo_key] %}
          <div class="ai-as-seen-on-logo-item-{{ ai_gen_id }}">
            {% if logo %}
              <img
                src="{{ logo | image_url: height: 200 }}"
                alt="{{ logo.alt | escape }}"
                loading="lazy"
                height="{{ block.settings.logo_height }}"
              >
            {% else %}
              <div class="ai-as-seen-on-logo-placeholder-{{ ai_gen_id }}">
                Logo {{ i }}
              </div>
            {% endif %}
          </div>
        {% endfor %}

        {% for i in (1..7) %}
          {% assign logo_key = 'logo_' | append: i %}
          {% assign logo = block.settings[logo_key] %}
          <div class="ai-as-seen-on-logo-item-{{ ai_gen_id }}">
            {% if logo %}
              <img
                src="{{ logo | image_url: height: 200 }}"
                alt="{{ logo.alt | escape }}"
                loading="lazy"
                height="{{ block.settings.logo_height }}"
              >
            {% else %}
              <div class="ai-as-seen-on-logo-placeholder-{{ ai_gen_id }}">
                Logo {{ i }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</as-seen-on-{{ ai_gen_id }}>

<script>
  (function() {
    class AsSeenOn{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.marquee = this.querySelector('.ai-as-seen-on-marquee-{{ ai_gen_id }}');
        this.adjustMarqueeSpeed();
      }

      adjustMarqueeSpeed() {
        if (!this.marquee) return;
        
        const logoCount = this.querySelectorAll('.ai-as-seen-on-logo-item-{{ ai_gen_id }}').length / 2;
        if (logoCount > 0) {
          const totalWidth = this.marquee.scrollWidth / 2;
          const speed = {{ block.settings.scroll_speed }};
          this.marquee.style.animationDuration = speed + 's';
        }
      }
    }

    customElements.define('as-seen-on-{{ ai_gen_id }}', AsSeenOn{{ ai_gen_id }});
  })();
</script>

