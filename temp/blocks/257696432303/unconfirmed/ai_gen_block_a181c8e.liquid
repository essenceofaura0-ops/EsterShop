{% doc %}
  @prompt
    Create a compact "As Seen On" homepage section for a Shopify drag brand called Ester Flonaze. Keep it smallish — don't let it take up too much vertical space.
    
    COPY (USE EXACTLY):
    - Top headline: "Granny's Been Around" — white text with subtle gold glow/text-shadow (#D4AF37)
    - Subheadline below: "As Seen On" — purple (#C15CCF), slight letter spacing (0.1em)
    
    BACKGROUND:
    - Deep purple gradient: #1A1A2E → #2a1f3d
    - Very subtle sparkle/glow texture overlay (low opacity gold/purple CSS dots)
    - No flat or white backgrounds
    
    HEADLINE FONT: Playfair Display Bold (Google Fonts), large, centered
    SUBHEADLINE FONT: Raleway or Montserrat, smaller, centered
    
    LOGO MARQUEE (CRITICAL):
    - Exactly 7 logo image blocks — no more, no less. Hard limit of 7 image picker fields in the schema.
    - Horizontal infinite auto-scrolling marquee (CSS animation, seamless loop)
    - All logos same consistent height, evenly spaced
    - Default: grayscale, 75% opacity
    - Hover: pause animation, full color, slight brightness increase
    - Slow, smooth scroll speed
    
    GOLD DIVIDER:
    - Thin gold line (#D4AF37) above the logo row with subtle glow
    
    LAYOUT:
    - Headline top, subheadline below, gold divider, then scrolling logos
    - Everything centered, compact vertical padding
    
    MOBILE:
    - Marquee scrolls smoothly, logos readable, strong hierarchy
    
    VIBE: "She's legit and she's fabulous." Drag glam meets media credibility. Dawn-compatible Shopify section.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Raleway:wght@400;500&display=swap" rel="stylesheet">

{% style %}
  .ai-as-seen-on-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background: linear-gradient(180deg, #1A1A2E 0%, #2a1f3d 100%);
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    position: relative;
    overflow: hidden;
  }

  .ai-as-seen-on-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
      radial-gradient(circle, rgba(212, 175, 55, 0.15) 1px, transparent 1px),
      radial-gradient(circle, rgba(193, 92, 207, 0.1) 1px, transparent 1px);
    background-size: 50px 50px, 80px 80px;
    background-position: 0 0, 40px 40px;
    pointer-events: none;
    opacity: 0.4;
  }

  .ai-as-seen-on-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .ai-as-seen-on-headline-{{ ai_gen_id }} {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: {{ block.settings.headline_size }}px;
    color: #FFFFFF;
    text-align: center;
    margin: 0 0 8px;
    text-shadow: 0 0 20px rgba(212, 175, 55, 0.6), 0 0 40px rgba(212, 175, 55, 0.3);
    line-height: 1.2;
  }

  .ai-as-seen-on-subheadline-{{ ai_gen_id }} {
    font-family: 'Raleway', sans-serif;
    font-weight: 500;
    font-size: {{ block.settings.subheadline_size }}px;
    color: #C15CCF;
    text-align: center;
    margin: 0 0 {{ block.settings.divider_spacing }}px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .ai-as-seen-on-divider-{{ ai_gen_id }} {
    width: 100%;
    max-width: 600px;
    height: 1px;
    background: #D4AF37;
    margin: 0 auto {{ block.settings.divider_spacing }}px;
    box-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
  }

  .ai-as-seen-on-marquee-wrapper-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .ai-as-seen-on-marquee-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.logo_spacing }}px;
    animation: ai-as-seen-on-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-as-seen-on-marquee-{{ ai_gen_id }}:hover {
    animation-play-state: paused;
  }

  .ai-as-seen-on-logo-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-as-seen-on-logo-item-{{ ai_gen_id }} img {
    height: 100%;
    width: auto;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.75;
    transition: all 0.3s ease;
  }

  .ai-as-seen-on-marquee-{{ ai_gen_id }}:hover .ai-as-seen-on-logo-item-{{ ai_gen_id }} img {
    filter: grayscale(0%);
    opacity: 1;
    filter: brightness(1.1);
  }

  .ai-as-seen-on-logo-placeholder-{{ ai_gen_id }} {
    height: 100%;
    width: 150px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.75;
  }

  .ai-as-seen-on-logo-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
  }

  @keyframes ai-as-seen-on-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-as-seen-on-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px 15px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-as-seen-on-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.6 }}px;
    }

    .ai-as-seen-on-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.8 }}px;
    }

    .ai-as-seen-on-logo-item-{{ ai_gen_id }} {
      height: {{ block.settings.logo_height | times: 0.7 }}px;
    }
  }
{% endstyle %}

<as-seen-on-{{ ai_gen_id }} class="ai-as-seen-on-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-as-seen-on-container-{{ ai_gen_id }}">
    <h2 class="ai-as-seen-on-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    <p class="ai-as-seen-on-subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</p>
    
    <div class="ai-as-seen-on-divider-{{ ai_gen_id }}"></div>
    
    <div class="ai-as-seen-on-marquee-wrapper-{{ ai_gen_id }}">
      <div class="ai-as-seen-on-marquee-{{ ai_gen_id }}" data-marquee>
        {% liquid
          assign logo_keys = 'logo_1,logo_2,logo_3,logo_4,logo_5,logo_6,logo_7' | split: ','
          assign logos_array = ''
          
          for key in logo_keys
            assign logo = block.settings[key]
            if logo != blank
              assign logos_array = logos_array | append: key | append: ','
            endif
          endfor
          
          assign logos_array = logos_array | split: ','
          assign logos_count = logos_array.size
        %}
        
        {% if logos_count > 0 %}
          {% for i in (1..2) %}
            {% for key in logos_array %}
              {% if key != blank %}
                {% assign logo = block.settings[key] %}
                <div class="ai-as-seen-on-logo-item-{{ ai_gen_id }}">
                  <img 
                    src="{{ logo | image_url: height: block.settings.logo_height | times: 2 }}" 
                    alt="{{ logo.alt | escape }}"
                    loading="lazy"
                    height="{{ block.settings.logo_height }}"
                  >
                </div>
              {% endif %}
            {% endfor %}
          {% endfor %}
        {% else %}
          {% for i in (1..14) %}
            <div class="ai-as-seen-on-logo-item-{{ ai_gen_id }}">
              <div class="ai-as-seen-on-logo-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</as-seen-on-{{ ai_gen_id }}>

<script>
  (function() {
    class AsSeenOn{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.marquee = this.querySelector('[data-marquee]');
        this.adjustMarqueeSpeed();
      }

      adjustMarqueeSpeed() {
        if (!this.marquee) return;
        
        const items = this.marquee.querySelectorAll('.ai-as-seen-on-logo-item-{{ ai_gen_id }}');
        if (items.length === 0) return;
      }
    }

    customElements.define('as-seen-on-{{ ai_gen_id }}', AsSeenOn{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "As seen on",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Granny's Been Around"
