{% doc %}
  @prompt
    Create a homepage “As Seen On” section for my Shopify store for a drag brand called Ester Flonaze.
    
    🚨 REQUIREMENTS:
    Must include:
    A bold headline
    A subheadline
    A rotating / scrolling row of logos
    Logos must be added as editable image blocks in Shopify Theme Editor
    Must be fully responsive (carousel or scroll on mobile)
    📝 COPY (USE EXACTLY):
    
    Headline:
    Granny’s Been Around
    
    Subheadline:
    As Seen On
    
    🎨 DESIGN DIRECTION:
    Overall Vibe
    Glamorous
    Slightly gaudy (in a tasteful drag way)
    Eye-catching but still clean
    Feels like credibility + personality combined
    Background (IMPORTANT)
    Do NOT use plain white
    Use one of:
    Deep purple gradient (#1A1A2E → #2a1f3d)
    OR soft lavender (#E8D5F5) with subtle texture
    Add depth — no flat backgrounds
    Headline Styling
    Use a bold theatrical font (Playfair Display or similar)
    Large, centered
    Add subtle gold or purple glow/accent
    Subheadline Styling
    Smaller than headline
    Centered
    Slight letter spacing
    Clean and elegant
    Logo Section (MOST IMPORTANT)
    Create a horizontal scrolling / marquee-style row of logos
    Logos must:
    Be uploaded via image blocks
    Be evenly sized and aligned
    Maintain consistent height
    Behavior:
    Logos should slowly auto-scroll horizontally
    Loop seamlessly (infinite scroll effect)
    On hover:
    Pause animation
    Fade logos from grayscale → full color
    Styling for Logos
    Default:
    Grayscale
    Slight opacity (like 70–80%)
    Hover:
    Full color
    Slight brightness increase
    Layout
    Headline at top
    Subheadline below
    Logos directly under
    Center everything
    Add generous vertical spacing
    Accent Details
    Add thin gold divider line (#D4AF37) above or below logos
    Optional subtle sparkle/glow effect in background (VERY subtle)
    📱 MOBILE REQUIREMENTS:
    Logos should become:
    Horizontal swipe OR scroll carousel
    Maintain spacing and readability
    Animation should still feel smooth
    ⚠️ AVOID:
    Static logo grid (must move or scroll)
    Default Shopify styling
    Uneven logo sizes
    Overly flashy or tacky animation
    White background
    🎭 VIBE:
    “She’s legit and she’s fabulous”
    Drag performer meets media credibility
    Clean but with personality
    📦 OUTPUT:
    Shopify Dawn-compatible section
    Editable logo image blocks
    Smooth scrolling animation
    Fully responsive
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-as-seen-on-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: {{ block.settings.background_gradient }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    position: relative;
    overflow: hidden;
  }

  .ai-as-seen-on-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at 20% 50%, rgba(212, 175, 55, 0.05) 0%, transparent 50%),
                radial-gradient(circle at 80% 50%, rgba(138, 43, 226, 0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  .ai-as-seen-on-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .ai-as-seen-on-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-as-seen-on-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size }}px;
    color: {{ block.settings.subheadline_color }};
    letter-spacing: {{ block.settings.subheadline_letter_spacing }}px;
    text-transform: uppercase;
    margin: 0 0 {{ block.settings.subheadline_margin }}px;
    font-weight: 400;
  }

  .ai-as-seen-on-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    color: {{ block.settings.headline_color }};
    margin: 0;
    font-weight: 700;
    line-height: 1.2;
    text-shadow: 0 0 {{ block.settings.headline_glow }}px {{ block.settings.headline_glow_color }};
  }

  .ai-as-seen-on-divider-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}px;
    height: {{ block.settings.divider_thickness }}px;
    background: {{ block.settings.divider_color }};
    margin: {{ block.settings.divider_spacing }}px auto;
    box-shadow: 0 0 10px {{ block.settings.divider_color }};
  }

  .ai-as-seen-on-marquee-wrapper-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .ai-as-seen-on-marquee-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.logo_spacing }}px;
    animation: ai-as-seen-on-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  .ai-as-seen-on-marquee-{{ ai_gen_id }}:hover {
    animation-play-state: paused;
  }

  .ai-as-seen-on-logo-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 {{ block.settings.logo_padding }}px;
    transition: all 0.4s ease;
  }

  .ai-as-seen-on-logo-item-{{ ai_gen_id }} img {
    max-height: 100%;
    width: auto;
    max-width: {{ block.settings.logo_max_width }}px;
    object-fit: contain;
    filter: grayscale({{ block.settings.logo_grayscale }}%) opacity({{ block.settings.logo_opacity }}%);
    transition: filter 0.4s ease, transform 0.4s ease;
  }

  .ai-as-seen-on-logo-item-{{ ai_gen_id }}:hover img {
    filter: grayscale(0%) opacity(100%) brightness({{ block.settings.logo_hover_brightness }}%);
    transform: scale(1.05);
  }

  .ai-as-seen-on-logo-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.logo_max_width }}px;
    height: {{ block.settings.logo_height }}px;
    background: rgba(255, 255, 255, 0.1);
    border: 2px dashed rgba(255, 255, 255, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }

  .ai-as-seen-on-logo-placeholder-{{ ai_gen_id }} svg {
    width: 40px;
    height: 40px;
    opacity: 0.3;
  }

  @keyframes ai-as-seen-on-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-as-seen-on-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 15px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-as-seen-on-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.6 }}px;
    }

    .ai-as-seen-on-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.8 }}px;
    }

    .ai-as-seen-on-logo-item-{{ ai_gen_id }} {
      height: {{ block.settings.logo_height | times: 0.7 }}px;
    }

    .ai-as-seen-on-logo-item-{{ ai_gen_id }} img {
      max-width: {{ block.settings.logo_max_width | times: 0.7 }}px;
    }

    .ai-as-seen-on-logo-placeholder-{{ ai_gen_id }} {
      width: {{ block.settings.logo_max_width | times: 0.7 }}px;
      height: {{ block.settings.logo_height | times: 0.7 }}px;
    }
  }
{% endstyle %}

<as-seen-on-{{ ai_gen_id }} class="ai-as-seen-on-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-as-seen-on-container-{{ ai_gen_id }}">
    <div class="ai-as-seen-on-header-{{ ai_gen_id }}">
      {% if block.settings.subheadline != blank %}
        <div class="ai-as-seen-on-subheadline-{{ ai_gen_id }}">
          {{ block.settings.subheadline }}
        </div>
      {% endif %}
      
      {% if block.settings.headline != blank %}
        <h2 class="ai-as-seen-on-headline-{{ ai_gen_id }}">
          {{ block.settings.headline }}
        </h2>
      {% endif %}
    </div>

    {% if block.settings.show_divider %}
      <div class="ai-as-seen-on-divider-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-as-seen-on-marquee-wrapper-{{ ai_gen_id }}">
      <div class="ai-as-seen-on-marquee-{{ ai_gen_id }}" data-marquee>
        {% for i in (1..2) %}
          {% for j in (1..8) %}
            {% assign logo_key = 'logo_' | append: j %}
            {% assign logo = block.settings[logo_key] %}
            {% if logo != blank %}
              <div class="ai-as-seen-on-logo-item-{{ ai_gen_id }}">
                <img
                  src="{{ logo | image_url: width: 400 }}"
                  alt="{{ logo.alt | default: 'Media logo' | escape }}"
                  loading="lazy"
                  width="{{ logo.width }}"
                  height="{{ logo.height }}"
                >
              </div>
            {% else %}
              <div class="ai-as-seen-on-logo-item-{{ ai_gen_id }}">
                <div class="ai-as-seen-on-logo-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  </div>
</as-seen-on-{{ ai_gen_id }}>

<script>
  (function() {
    class AsSeenOn{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.marquee = this.querySelector('[data-marquee]');
        this.setupMarquee();
      }

      setupMarquee() {
        if (!this.marquee) return;

        const items = this.marquee.querySelectorAll('.ai-as-seen-on-logo-item-{{ ai_gen_id }}');
        if (items.length === 0) return;

        const firstHalf = Array.from(items).slice(0, items.length / 2);
        const totalWidth = firstHalf.reduce(function(sum, item) {
          return sum + item.offsetWidth + {{ block.settings.logo_spacing }};
        }, 0);

        this.marquee.style.width = totalWidth * 2 + 'px';
      }
    }

    customElements.define('as-seen-on-{{ ai_gen_id }}', AsSeenOn{{ ai_gen_id }});
  })();
</script>

