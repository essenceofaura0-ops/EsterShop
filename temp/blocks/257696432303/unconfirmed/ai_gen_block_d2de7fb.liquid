{% doc %}
  @prompt
    Create a fully functional, custom header and navigation menu section for a Shopify store called "Ester Flonaze" — a bold, theatrical drag performer brand. This must replace the existing header and function as the real site navigation.
    
    FUNCTIONAL REQUIREMENTS:
    - Pull navigation links from the store's "main-menu" link list (use Liquid: linklists.main-menu.links)
    - Include a mobile-responsive hamburger menu that toggles open/closed
    - Vertically center logo text and nav items
    - Logo text should read "Ester Flonaze" and link to the homepage
    - Include search icon, account icon (person), and cart icon (shopping bag) — all functional and styled to match the brand
    
    BACKGROUND:
    - Use a subtle gradient background: from #1A1A2E (Deep Midnight) to a slightly purple-tinted tone like #1E1535 — deep and rich, not loud
    - Add a very soft shimmer/glitter texture overlay using CSS — think drag stage lighting, extremely subtle
    
    GOLD ACCENT LINE:
    - Add a thin (2–3px) gold (#D4AF37) line along the bottom of the header
    - Give it a soft glowing animation (pulsing glow using CSS keyframes)
    
    TYPOGRAPHY:
    - Import "Playfair Display" Bold from Google Fonts for the logo
    - Import "Raleway" or "Montserrat" for nav items
    - Slight letter spacing on nav items (0.08em)
    
    NAVIGATION HOVER EFFECTS:
    - Default nav text color: #C15CCF (vibrant purple)
    - On hover: shift to #D4AF37 (gold) with a soft purple/pink text-shadow glow
    - Smooth 150–200ms transition
    - Animated underline that slides in from left on hover
    
    ICONS:
    - Search, account (person), and cart (shopping bag) icons styled in gold (#D4AF37)
    - Functional links to search, account, and cart pages
    - Hover effect with subtle glow
    
    MOBILE:
    - Hamburger icon in gold (#D4AF37)
    - Mobile menu drops down with same dark gradient background
    - Mobile nav links styled consistently
    
    VIBE: Drag show lighting, Catholic glam meets nightlife, bingo hall chaos but elevated — campy but clean. Premium, flashy, and alive.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Raleway:wght@400;500;600&display=swap" rel="stylesheet">

{% style %}
  .ai-ester-header-{{ ai_gen_id }} {
    display: block;
    position: sticky;
    top: 0;
    z-index: 1000;
    width: 100%;
    background: linear-gradient(135deg, #1A1A2E 0%, #1E1535 100%);
    position: relative;
    overflow: hidden;
  }

  .ai-ester-header-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
      radial-gradient(circle at 20% 50%, rgba(212, 175, 55, 0.03) 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, rgba(193, 92, 207, 0.03) 0%, transparent 50%),
      radial-gradient(circle at 40% 20%, rgba(212, 175, 55, 0.02) 0%, transparent 50%);
    pointer-events: none;
    animation: ai-ester-shimmer-{{ ai_gen_id }} 8s ease-in-out infinite;
  }

  @keyframes ai-ester-shimmer-{{ ai_gen_id }} {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.7; }
  }

  .ai-ester-header-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 1;
  }

  .ai-ester-header-inner-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
    gap: 40px;
  }

  .ai-ester-logo-{{ ai_gen_id }} {
    flex-shrink: 0;
  }

  .ai-ester-logo-link-{{ ai_gen_id }} {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 28px;
    color: #D4AF37;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .ai-ester-logo-link-{{ ai_gen_id }}:hover {
    color: #C15CCF;
    text-shadow: 0 0 20px rgba(193, 92, 207, 0.6);
  }

  .ai-ester-nav-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    justify-content: center;
  }

  .ai-ester-nav-list-{{ ai_gen_id }} {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 35px;
    align-items: center;
  }

  .ai-ester-nav-item-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-ester-nav-link-{{ ai_gen_id }} {
    font-family: 'Raleway', sans-serif;
    font-weight: 500;
    font-size: 15px;
    color: #C15CCF;
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: all 0.18s ease;
    position: relative;
    display: inline-block;
    padding-bottom: 4px;
  }

  .ai-ester-nav-link-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: #D4AF37;
    transition: width 0.18s ease;
    box-shadow: 0 0 8px rgba(212, 175, 55, 0.6);
  }

  .ai-ester-nav-link-{{ ai_gen_id }}:hover {
    color: #D4AF37;
    text-shadow: 0 0 12px rgba(193, 92, 207, 0.5);
  }

  .ai-ester-nav-link-{{ ai_gen_id }}:hover::after {
    width: 100%;
  }

  .ai-ester-icons-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-shrink: 0;
  }

  .ai-ester-icon-link-{{ ai_gen_id }} {
    color: #D4AF37;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.18s ease;
    position: relative;
  }

  .ai-ester-icon-link-{{ ai_gen_id }} svg {
    width: 22px;
    height: 22px;
    stroke-width: 2;
  }

  .ai-ester-icon-link-{{ ai_gen_id }}:hover {
    color: #C15CCF;
    filter: drop-shadow(0 0 8px rgba(212, 175, 55, 0.7));
  }

  .ai-ester-cart-count-{{ ai_gen_id }} {
    position: absolute;
    top: -8px;
    right: -8px;
    background: #C15CCF;
    color: #fff;
    font-family: 'Raleway', sans-serif;
    font-size: 11px;
    font-weight: 600;
    border-radius: 50%;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 10px rgba(193, 92, 207, 0.6);
  }

  .ai-ester-hamburger-{{ ai_gen_id }} {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .ai-ester-hamburger-line-{{ ai_gen_id }} {
    width: 26px;
    height: 2px;
    background: #D4AF37;
    transition: all 0.3s ease;
    box-shadow: 0 0 6px rgba(212, 175, 55, 0.5);
  }

  .ai-ester-hamburger-{{ ai_gen_id }}.active .ai-ester-hamburger-line-{{ ai_gen_id }}:nth-child(1) {
    transform: rotate(45deg) translate(7px, 7px);
  }

  .ai-ester-hamburger-{{ ai_gen_id }}.active .ai-ester-hamburger-line-{{ ai_gen_id }}:nth-child(2) {
    opacity: 0;
  }

  .ai-ester-hamburger-{{ ai_gen_id }}.active .ai-ester-hamburger-line-{{ ai_gen_id }}:nth-child(3) {
    transform: rotate(-45deg) translate(7px, -7px);
  }

  .ai-ester-mobile-menu-{{ ai_gen_id }} {
    display: none;
    background: linear-gradient(135deg, #1A1A2E 0%, #1E1535 100%);
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
  }

  .ai-ester-mobile-menu-{{ ai_gen_id }}.active {
    max-height: 500px;
  }

  .ai-ester-mobile-nav-list-{{ ai_gen_id }} {
    list-style: none;
    margin: 0;
    padding: 20px;
  }

  .ai-ester-mobile-nav-item-{{ ai_gen_id }} {
    border-bottom: 1px solid rgba(212, 175, 55, 0.15);
  }

  .ai-ester-mobile-nav-item-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-ester-mobile-nav-link-{{ ai_gen_id }} {
    font-family: 'Raleway', sans-serif;
    font-weight: 500;
    font-size: 16px;
    color: #C15CCF;
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    display: block;
    padding: 15px 10px;
    transition: all 0.18s ease;
  }

  .ai-ester-mobile-nav-link-{{ ai_gen_id }}:hover {
    color: #D4AF37;
    padding-left: 20px;
    text-shadow: 0 0 12px rgba(193, 92, 207, 0.5);
  }

  .ai-ester-gold-line-{{ ai_gen_id }} {
    height: 3px;
    background: #D4AF37;
    box-shadow: 0 0 12px rgba(212, 175, 55, 0.6);
    animation: ai-ester-glow-{{ ai_gen_id }} 2s ease-in-out infinite;
  }

  @keyframes ai-ester-glow-{{ ai_gen_id }} {
    0%, 100% {
      box-shadow: 0 0 12px rgba(212, 175, 55, 0.6);
    }
    50% {
      box-shadow: 0 0 20px rgba(212, 175, 55, 0.9), 0 0 30px rgba(212, 175, 55, 0.5);
    }
  }

  @media screen and (max-width: 990px) {
    .ai-ester-nav-{{ ai_gen_id }} {
      display: none;
    }

    .ai-ester-hamburger-{{ ai_gen_id }} {
      display: flex;
    }

    .ai-ester-mobile-menu-{{ ai_gen_id }} {
      display: block;
    }

    .ai-ester-header-inner-{{ ai_gen_id }} {
      height: 70px;
    }

    .ai-ester-logo-link-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-ester-icons-{{ ai_gen_id }} {
      gap: 15px;
    }
  }

  @media screen and (max-width: 550px) {
    .ai-ester-header-container-{{ ai_gen_id }} {
      padding: 0 15px;
    }

    .ai-ester-logo-link-{{ ai_gen_id }} {
      font-size: 20px;
    }

    .ai-ester-icon-link-{{ ai_gen_id }} svg {
      width: 20px;
      height: 20px;
    }
  }
{% endstyle %}

<ester-header-{{ ai_gen_id }} class="ai-ester-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ester-header-container-{{ ai_gen_id }}">
    <div class="ai-ester-header-inner-{{ ai_gen_id }}">
      <div class="ai-ester-logo-{{ ai_gen_id }}">
        <a href="/" class="ai-ester-logo-link-{{ ai_gen_id }}">Ester Flonaze</a>
      </div>

      <nav class="ai-ester-nav-{{ ai_gen_id }}" aria-label="Main navigation">
        <ul class="ai-ester-nav-list-{{ ai_gen_id }}">
          {% for link in linklists.main-menu.links %}
            <li class="ai-ester-nav-item-{{ ai_gen_id }}">
              <a href="{{ link.url }}" class="ai-ester-nav-link-{{ ai_gen_id }}">{{ link.title }}</a>
            </li>
          {% endfor %}
        </ul>
      </nav>

      <div class="ai-ester-icons-{{ ai_gen_id }}">
        <a href="/search" class="ai-ester-icon-link-{{ ai_gen_id }}" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
        </a>

        <a href="/account" class="ai-ester-icon-link-{{ ai_gen_id }}" aria-label="Account">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </a>

        <a href="/cart" class="ai-ester-icon-link-{{ ai_gen_id }}" aria-label="Cart">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <path d="M16 10a4 4 0 0 1-8 0"></path>
          </svg>
          {% if cart.item_count > 0 %}
            <span class="ai-ester-cart-count-{{ ai_gen_id }}">{{ cart.item_count }}</span>
          {% endif %}
        </a>

        <button class="ai-ester-hamburger-{{ ai_gen_id }}" aria-label="Toggle menu" aria-expanded="false">
          <span class="ai-ester-hamburger-line-{{ ai_gen_id }}"></span>
          <span class="ai-ester-hamburger-line-{{ ai_gen_id }}"></span>
          <span class="ai-ester-hamburger-line-{{ ai_gen_id }}"></span>
        </button>
      </div>
    </div>

    <nav class="ai-ester-mobile-menu-{{ ai_gen_id }}" aria-label="Mobile navigation">
      <ul class="ai-ester-mobile-nav-list-{{ ai_gen_id }}">
        {% for link in linklists.main-menu.links %}
          <li class="ai-ester-mobile-nav-item-{{ ai_gen_id }}">
            <a href="{{ link.url }}" class="ai-ester-mobile-nav-link-{{ ai_gen_id }}">{{ link.title }}</a>
          </li>
        {% endfor %}
      </ul>
    </nav>
  </div>

  <div class="ai-ester-gold-line-{{ ai_gen_id }}"></div>
</ester-header-{{ ai_gen_id }}>

<script>
  (function() {
    class EsterHeader{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.hamburger = this.querySelector('.ai-ester-hamburger-{{ ai_gen_id }}');
        this.mobileMenu = this.querySelector('.ai-ester-mobile-menu-{{ ai_gen_id }}');
        this.mobileLinks = this.querySelectorAll('.ai-ester-mobile-nav-link-{{ ai_gen_id }}');
      }

      connectedCallback() {
        if (this.hamburger && this.mobileMenu) {
          this.hamburger.addEventListener('click', () => this.toggleMenu());
          
          this.mobileLinks.forEach(link => {
            link.addEventListener('click', () => this.closeMenu());
          });

          document.addEventListener('click', (e) => {
            if (!this.contains(e.target) && this.mobileMenu.classList.contains('active')) {
              this.closeMenu();
            }
          });
        }
      }

      toggleMenu() {
        const isActive = this.mobileMenu.classList.contains('active');
        
        if (isActive) {
          this.closeMenu();
        } else {
          this.openMenu();
        }
      }

      openMenu() {
        this.hamburger.classList.add('active');
        this.mobileMenu.classList.add('active');
        this.hamburger.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }

      closeMenu() {
        this.hamburger.classList.remove('active');
        this.mobileMenu.classList.remove('active');
        this.hamburger.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
    }

    customElements.define('ester-header-{{ ai_gen_id }}', EsterHeader{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Ester Flonaze header",
  "settings": [
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "paragraph",
      "content": "This header pulls navigation links from your main-menu. To edit menu items, go to Navigation in your admin."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Ester Flonaze header"
    }
  ]
}
{% endschema %}
