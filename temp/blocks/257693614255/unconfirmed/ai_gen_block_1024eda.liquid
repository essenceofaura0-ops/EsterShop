{% doc %}
  @prompt
    Update an existing custom Shopify header section for a drag performer brand called "Ester Flonaze" to add utility icons on the right side. The header already has: logo text "Ester Flonaze" in purple (#C15CCF) with Playfair Display font, a dark gradient background (#1A1A2E to #1E1535), navigation links from linklists.main-menu.links in purple with gold hover effects, a pulsing gold bottom border, and a mobile hamburger menu.
    
    ADD these three utility icons to the RIGHT side of the header:
    
    1. SEARCH ICON - clicking opens an inline or dropdown search bar
    2. ACCOUNT ICON - links to {{ routes.account_url }} (customer login/account page)
    3. CART ICON - links to {{ routes.cart_url }} with a small badge showing {{ cart.item_count }} when items are in the cart
    
    STYLING for all icons:
    - Color: #D4AF37 (gold)
    - On hover: subtle glow or brightness increase, smooth 150-200ms transition
    - Size: clean and proportional, not too large
    - Badge on cart: small gold circle with dark text showing item count, only visible when count > 0
    - Icons should use clean SVG icons (search magnifier, person silhouette, shopping bag)
    
    LAYOUT:
    - Icons sit to the right of the navigation links
    - Properly spaced and vertically centered
    - On mobile: icons remain visible alongside or near the hamburger menu
    
    Keep all existing styles and functionality intact — only add these icons.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ester-header-{{ ai_gen_id }} {
    display: block;
    background: linear-gradient(135deg, #1A1A2E 0%, #1E1535 100%);
    position: relative;
    width: 100%;
  }

  .ester-header-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: #D4AF37;
    animation: ester-pulse-{{ ai_gen_id }} 2s ease-in-out infinite;
  }

  @keyframes ester-pulse-{{ ai_gen_id }} {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }

  .ester-header__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 30px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
  }

  .ester-header__logo-{{ ai_gen_id }} {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    color: #C15CCF;
    text-decoration: none;
    font-weight: 700;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ester-header__nav-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 30px;
    flex-grow: 1;
  }

  .ester-header__menu-{{ ai_gen_id }} {
    display: flex;
    gap: 25px;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-grow: 1;
  }

  .ester-header__menu-item-{{ ai_gen_id }} {
    margin: 0;
  }

  .ester-header__menu-link-{{ ai_gen_id }} {
    color: #C15CCF;
    text-decoration: none;
    font-size: 16px;
    transition: color 0.2s ease;
  }

  .ester-header__menu-link-{{ ai_gen_id }}:hover {
    color: #D4AF37;
  }

  .ester-header__utilities-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-shrink: 0;
  }

  .ester-header__utility-btn-{{ ai_gen_id }} {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: #D4AF37;
    transition: filter 0.15s ease;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ester-header__utility-btn-{{ ai_gen_id }}:hover {
    filter: brightness(1.3);
  }

  .ester-header__utility-btn-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ester-header__utility-link-{{ ai_gen_id }} {
    color: #D4AF37;
    text-decoration: none;
    transition: filter 0.15s ease;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ester-header__utility-link-{{ ai_gen_id }}:hover {
    filter: brightness(1.3);
  }

  .ester-header__utility-link-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ester-header__cart-badge-{{ ai_gen_id }} {
    position: absolute;
    top: -8px;
    right: -8px;
    background: #D4AF37;
    color: #1A1A2E;
    border-radius: 50%;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
  }

  .ester-header__search-bar-{{ ai_gen_id }} {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #1E1535;
    padding: 20px 30px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: opacity 0.2s ease, visibility 0.2s ease, transform 0.2s ease;
    z-index: 100;
  }

  .ester-header__search-bar-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .ester-header__search-form-{{ ai_gen_id }} {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    gap: 10px;
  }

  .ester-header__search-input-{{ ai_gen_id }} {
    flex-grow: 1;
    padding: 12px 16px;
    border: 2px solid #C15CCF;
    background: #1A1A2E;
    color: #FFFFFF;
    border-radius: 4px;
    font-size: 16px;
  }

  .ester-header__search-input-{{ ai_gen_id }}::placeholder {
    color: #999;
  }

  .ester-header__search-submit-{{ ai_gen_id }} {
    padding: 12px 24px;
    background: #D4AF37;
    color: #1A1A2E;
    border: none;
    border-radius: 4px;
    font-weight: 700;
    cursor: pointer;
    transition: filter 0.15s ease;
  }

  .ester-header__search-submit-{{ ai_gen_id }}:hover {
    filter: brightness(1.1);
  }

  .ester-header__mobile-toggle-{{ ai_gen_id }} {
    display: none;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    color: #D4AF37;
    flex-shrink: 0;
  }

  .ester-header__mobile-toggle-{{ ai_gen_id }} svg {
    width: 28px;
    height: 28px;
  }

  @media screen and (max-width: 990px) {
    .ester-header__container-{{ ai_gen_id }} {
      padding: 15px 20px;
    }

    .ester-header__logo-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ester-header__menu-{{ ai_gen_id }} {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: #1E1535;
      flex-direction: column;
      padding: 20px;
      gap: 15px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
    }

    .ester-header__menu-{{ ai_gen_id }}.active {
      display: flex;
    }

    .ester-header__nav-{{ ai_gen_id }} {
      position: static;
    }

    .ester-header__mobile-toggle-{{ ai_gen_id }} {
      display: block;
    }

    .ester-header__utilities-{{ ai_gen_id }} {
      gap: 15px;
    }

    .ester-header__utility-btn-{{ ai_gen_id }} svg,
    .ester-header__utility-link-{{ ai_gen_id }} svg {
      width: 22px;
      height: 22px;
    }
  }

  @media screen and (max-width: 749px) {
    .ester-header__container-{{ ai_gen_id }} {
      gap: 15px;
    }

    .ester-header__logo-{{ ai_gen_id }} {
      font-size: 20px;
    }

    .ester-header__utilities-{{ ai_gen_id }} {
      gap: 12px;
    }
  }
{% endstyle %}

<ester-header-{{ ai_gen_id }} class="ester-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ester-header__container-{{ ai_gen_id }}">
    <a href="/" class="ester-header__logo-{{ ai_gen_id }}">Ester Flonaze</a>

    <nav class="ester-header__nav-{{ ai_gen_id }}">
      <ul class="ester-header__menu-{{ ai_gen_id }}" id="ester-menu-{{ ai_gen_id }}">
        {% for link in linklists.main-menu.links %}
          <li class="ester-header__menu-item-{{ ai_gen_id }}">
            <a href="{{ link.url }}" class="ester-header__menu-link-{{ ai_gen_id }}">
              {{ link.title }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </nav>

    <div class="ester-header__utilities-{{ ai_gen_id }}">
      <button
        class="ester-header__utility-btn-{{ ai_gen_id }}"
        aria-label="Search"
        id="ester-search-toggle-{{ ai_gen_id }}"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>

      <a
        href="{{ routes.account_url }}"
        class="ester-header__utility-link-{{ ai_gen_id }}"
        aria-label="Account"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
      </a>

      <a
        href="{{ routes.cart_url }}"
        class="ester-header__utility-link-{{ ai_gen_id }}"
        aria-label="Cart"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        {% if cart.item_count > 0 %}
          <span class="ester-header__cart-badge-{{ ai_gen_id }}">{{ cart.item_count }}</span>
        {% endif %}
      </a>

      <button
        class="ester-header__mobile-toggle-{{ ai_gen_id }}"
        aria-label="Menu"
        id="ester-mobile-toggle-{{ ai_gen_id }}"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div class="ester-header__search-bar-{{ ai_gen_id }}" id="ester-search-bar-{{ ai_gen_id }}">
    <form action="{{ routes.search_url }}" method="get" class="ester-header__search-form-{{ ai_gen_id }}">
      <input
        type="search"
        name="q"
        class="ester-header__search-input-{{ ai_gen_id }}"
        placeholder="Search products..."
        aria-label="Search"
      >
      <button type="submit" class="ester-header__search-submit-{{ ai_gen_id }}">Search</button>
    </form>
  </div>
</ester-header-{{ ai_gen_id }}>

<script>
  (function() {
    class EsterHeader{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.searchToggle = this.querySelector('#ester-search-toggle-{{ ai_gen_id }}');
        this.searchBar = this.querySelector('#ester-search-bar-{{ ai_gen_id }}');
        this.mobileToggle = this.querySelector('#ester-mobile-toggle-{{ ai_gen_id }}');
        this.menu = this.querySelector('#ester-menu-{{ ai_gen_id }}');

        this.setupEventListeners();
      }

      setupEventListeners() {
        if (this.searchToggle && this.searchBar) {
          this.searchToggle.addEventListener('click', () => {
            const isActive = this.searchBar.classList.contains('active');
            this.searchBar.classList.toggle('active');
            
            if (!isActive) {
              const input = this.searchBar.querySelector('input');
              if (input) {
                setTimeout(() => input.focus(), 200);
              }
            }
          });

          document.addEventListener('click', (e) => {
            if (!this.searchBar.contains(e.target) && !this.searchToggle.contains(e.target)) {
              this.searchBar.classList.remove('active');
            }
          });
        }

        if (this.mobileToggle && this.menu) {
          this.mobileToggle.addEventListener('click', () => {
            this.menu.classList.toggle('active');
          });
        }
      }
    }

    customElements.define('ester-header-{{ ai_gen_id }}', EsterHeader{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Ester Flonaze header",
  "tag": null,
  "settings": [],
  "presets": [
    {
      "name": "Ester Flonaze header"
    }
  ]
}
{% endschema %}
