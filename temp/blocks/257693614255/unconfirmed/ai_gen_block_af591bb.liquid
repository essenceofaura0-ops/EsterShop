{% doc %}
  @prompt
    Redesign the header and navigation menu for a drag performer brand called "Ester Flonaze" with a bold, theatrical, premium nightlife aesthetic. Background: Keep #1A1A2E (Deep Midnight) as the base. Text & Colors: Change navigation menu text to #C15CCF (vibrant purple) for better contrast against the dark background. Logo/brand name should be prominent and slightly larger. Add gold (#D4AF37) accent for hover states. Typography: Use "Playfair Display" Bold or "Abril Fatface" for the logo/brand name (import from Google Fonts). Increase letter spacing on menu items slightly (0.05–0.1em) for elegance. Hover Effects: Smooth 150–200ms transition on all nav links. On hover: shift text color to #D4AF37 (gold), add a subtle purple/pink glow effect (text-shadow), and a slight brightness increase. Add an animated underline that slides in on hover. Layout: Increase spacing between menu items for a premium feel. Vertically center logo and nav items cleanly. Make the logo slightly more prominent in size. Vibe: drag show lighting, Catholic glam meets nightlife, bingo hall chaos but elevated — campy but clean. Avoid flat default Shopify styling, low contrast text, or overly tacky neon effects.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

{% style %}
  .ai-ester-header-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.vertical_padding }}px 0;
    position: relative;
    border-bottom: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
  }

  .ai-ester-header-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.horizontal_padding }}px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .ai-ester-logo-{{ ai_gen_id }} {
    font-family: 'Playfair Display', serif;
    font-size: {{ block.settings.logo_size }}px;
    font-weight: 700;
    color: {{ block.settings.logo_color }};
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: all 0.2s ease;
    text-transform: uppercase;
  }

  .ai-ester-logo-{{ ai_gen_id }}:hover {
    color: {{ block.settings.logo_hover_color }};
    text-shadow: 0 0 {{ block.settings.glow_intensity }}px {{ block.settings.logo_hover_color }};
  }

  .ai-ester-nav-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.nav_spacing }}px;
    align-items: center;
  }

  .ai-ester-nav-link-{{ ai_gen_id }} {
    position: relative;
    color: {{ block.settings.nav_text_color }};
    text-decoration: none;
    font-size: {{ block.settings.nav_font_size }}px;
    letter-spacing: {% assign letter_spacing_value = block.settings.letter_spacing_value | divided_by: 100.0 %}{{ letter_spacing_value }}em;
    text-transform: uppercase;
    font-weight: 500;
    transition: all {{ block.settings.transition_speed }}ms ease;
    padding-bottom: 4px;
  }

  .ai-ester-nav-link-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: {{ block.settings.nav_hover_color }};
    transition: width {{ block.settings.transition_speed }}ms ease;
  }

  .ai-ester-nav-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.nav_hover_color }};
    text-shadow: 0 0 {{ block.settings.glow_intensity }}px {{ block.settings.nav_glow_color }};
    filter: brightness({{ block.settings.hover_brightness }}%);
  }

  .ai-ester-nav-link-{{ ai_gen_id }}:hover::after {
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .ai-ester-header-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 20px;
    }

    .ai-ester-logo-{{ ai_gen_id }} {
      font-size: {{ block.settings.logo_size | times: 0.8 }}px;
    }

    .ai-ester-nav-{{ ai_gen_id }} {
      flex-wrap: wrap;
      justify-content: center;
      gap: {{ block.settings.nav_spacing | times: 0.7 }}px;
    }

    .ai-ester-nav-link-{{ ai_gen_id }} {
      font-size: {{ block.settings.nav_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<ester-header-{{ ai_gen_id }} class="ai-ester-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ester-header-container-{{ ai_gen_id }}">
    <a href="{{ block.settings.logo_link }}" class="ai-ester-logo-{{ ai_gen_id }}">
      {{ block.settings.brand_name }}
    </a>

    <nav class="ai-ester-nav-{{ ai_gen_id }}" role="navigation" aria-label="Main navigation">
      {% if block.settings.nav_link_1_text != blank %}
        <a href="{{ block.settings.nav_link_1_url }}" class="ai-ester-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_1_text }}
        </a>
      {% endif %}

      {% if block.settings.nav_link_2_text != blank %}
        <a href="{{ block.settings.nav_link_2_url }}" class="ai-ester-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_2_text }}
        </a>
      {% endif %}

      {% if block.settings.nav_link_3_text != blank %}
        <a href="{{ block.settings.nav_link_3_url }}" class="ai-ester-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_3_text }}
        </a>
      {% endif %}

      {% if block.settings.nav_link_4_text != blank %}
        <a href="{{ block.settings.nav_link_4_url }}" class="ai-ester-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_4_text }}
        </a>
      {% endif %}

      {% if block.settings.nav_link_5_text != blank %}
        <a href="{{ block.settings.nav_link_5_url }}" class="ai-ester-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_5_text }}
        </a>
      {% endif %}

      {% if block.settings.nav_link_6_text != blank %}
        <a href="{{ block.settings.nav_link_6_url }}" class="ai-ester-nav-link-{{ ai_gen_id }}">
          {{ block.settings.nav_link_6_text }}
        </a>
      {% endif %}
    </nav>
  </div>
</ester-header-{{ ai_gen_id }}>

<script>
  (function() {
    class EsterHeader{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const links = this.querySelectorAll('.ai-ester-nav-link-{{ ai_gen_id }}');
        links.forEach(link => {
          link.addEventListener('focus', function() {
            this.style.outline = '2px solid {{ block.settings.nav_hover_color }}';
            this.style.outlineOffset = '4px';
          });
          link.addEventListener('blur', function() {
            this.style.outline = '';
            this.style.outlineOffset = '';
          });
        });
      }
    }

    customElements.define('ester-header-{{ ai_gen_id }}', EsterHeader{{ ai_gen_id }});
  })();
</script>

