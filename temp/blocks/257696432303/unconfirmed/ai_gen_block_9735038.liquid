{% doc %}
  @prompt
    Create a compact "As Seen On" homepage section for a Shopify drag brand called Ester Flonaze. It should feel glamorous, slightly gaudy in a tasteful drag way, credible and full of personality. Keep it smallish — don't let it take up too much vertical space.
    
    COPY (USE EXACTLY):
    - Headline: "Granny's Been Around"
    - Subheadline: "As Seen On"
    
    BACKGROUND:
    - Deep purple gradient: #1A1A2E → #2a1f3d
    - Add subtle sparkle/glow texture overlay (very subtle radial gradients or CSS dots in gold/purple at low opacity)
    - No flat or white backgrounds
    
    HEADLINE STYLING:
    - Font: Playfair Display Bold (import from Google Fonts)
    - Large, centered
    - Subtle gold glow or accent (#D4AF37)
    
    SUBHEADLINE STYLING:
    - Smaller than headline, centered
    - Slight letter spacing (0.1em)
    - Clean and elegant, color: #C15CCF or soft gold
    
    LOGO MARQUEE (MOST IMPORTANT):
    - Horizontal infinite auto-scrolling marquee row (CSS animation, seamless loop)
    - Logos added as editable image blocks in Shopify Theme Editor (image picker fields, minimum 6 blocks)
    - All logos same consistent height, evenly spaced
    - Default state: grayscale, 75% opacity
    - Hover: pause animation, fade to full color, slight brightness increase
    - Smooth, slow scroll speed — not frantic
    
    GOLD DIVIDER:
    - Thin gold line (#D4AF37) above the logo row
    - Subtle glow effect
    
    LAYOUT:
    - Subheadline at top, then headline, then gold divider, then scrolling logos
    - Everything centered
    - Compact vertical padding — section should feel tight and purposeful, not sprawling
    
    MOBILE:
    - Marquee scroll continues smoothly on mobile
    - Logos maintain spacing and readability
    - Strong visual hierarchy
    
    VIBE: "She's legit and she's fabulous." Drag performer meets media credibility. Clean but with personality. Dawn-compatible Shopify section.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

{% style %}
  .ai-as-seen-on-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(180deg, {{ block.settings.gradient_start }} 0%, {{ block.settings.gradient_end }} 100%);
    position: relative;
    overflow: hidden;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
  }

  .ai-as-seen-on-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
      radial-gradient(circle at 20% 30%, {{ block.settings.sparkle_color_1 }} 0%, transparent 50%),
      radial-gradient(circle at 80% 70%, {{ block.settings.sparkle_color_2 }} 0%, transparent 50%),
      radial-gradient(circle at 50% 50%, {{ block.settings.sparkle_color_1 }} 0%, transparent 60%);
    opacity: {{ block.settings.sparkle_opacity }};
    pointer-events: none;
  }

  .ai-as-seen-on-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .ai-as-seen-on-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size }}px;
    color: {{ block.settings.subheadline_color }};
    text-align: center;
    margin: 0 0 {{ block.settings.subheadline_spacing }}px;
    letter-spacing: {{ block.settings.subheadline_letter_spacing }};
    text-transform: uppercase;
    font-weight: 400;
  }

  .ai-as-seen-on-headline-{{ ai_gen_id }} {
    font-family: 'Playfair Display', serif;
    font-size: {{ block.settings.headline_size }}px;
    color: {{ block.settings.headline_color }};
    text-align: center;
    margin: 0 0 {{ block.settings.headline_spacing }}px;
    font-weight: 700;
    text-shadow: 0 0 {{ block.settings.headline_glow }}px {{ block.settings.headline_glow_color }};
  }

  .ai-as-seen-on-divider-{{ ai_gen_id }} {
    height: {{ block.settings.divider_thickness }}px;
    background: {{ block.settings.divider_color }};
    margin: 0 auto {{ block.settings.divider_spacing }}px;
    max-width: {{ block.settings.divider_width }}%;
    box-shadow: 0 0 {{ block.settings.divider_glow }}px {{ block.settings.divider_color }};
  }

  .ai-as-seen-on-marquee-wrapper-{{ ai_gen_id }} {
    overflow: hidden;
    position: relative;
    width: 100%;
  }

  .ai-as-seen-on-marquee-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.logo_spacing }}px;
    animation: ai-as-seen-on-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-as-seen-on-marquee-{{ ai_gen_id }}:hover {
    animation-play-state: paused;
  }

  .ai-as-seen-on-logo-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    transition: all 0.4s ease;
  }

  .ai-as-seen-on-logo-item-{{ ai_gen_id }} img {
    height: 100%;
    width: auto;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: {{ block.settings.logo_opacity }};
    transition: all 0.4s ease;
  }

  .ai-as-seen-on-marquee-{{ ai_gen_id }}:hover .ai-as-seen-on-logo-item-{{ ai_gen_id }} img {
    filter: grayscale(0%);
    opacity: 1;
    filter: brightness({{ block.settings.logo_hover_brightness }});
  }

  .ai-as-seen-on-logo-placeholder-{{ ai_gen_id }} {
    width: 150px;
    height: {{ block.settings.logo_height }}px;
    background: rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.3);
    font-size: 12px;
    text-align: center;
    padding: 10px;
    border-radius: 4px;
  }

  @keyframes ai-as-seen-on-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-as-seen-on-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px 16px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-as-seen-on-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.6 }}px;
    }

    .ai-as-seen-on-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.8 }}px;
    }

    .ai-as-seen-on-logo-item-{{ ai_gen_id }} {
      height: {{ block.settings.logo_height | times: 0.7 }}px;
    }
  }
{% endstyle %}

<as-seen-on-{{ ai_gen_id }} class="ai-as-seen-on-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-as-seen-on-container-{{ ai_gen_id }}">
    <div class="ai-as-seen-on-subheadline-{{ ai_gen_id }}">
      As Seen On
    </div>

    <h2 class="ai-as-seen-on-headline-{{ ai_gen_id }}">
      Granny's Been Around
    </h2>

    <div class="ai-as-seen-on-divider-{{ ai_gen_id }}"></div>

    <div class="ai-as-seen-on-marquee-wrapper-{{ ai_gen_id }}">
      <div class="ai-as-seen-on-marquee-{{ ai_gen_id }}">
        {% for i in (1..10) %}
          {% assign logo_key = 'logo_' | append: i %}
          {% assign logo = block.settings[logo_key] %}
          {% if logo %}
            <div class="ai-as-seen-on-logo-item-{{ ai_gen_id }}">
              <img
                src="{{ logo | image_url: width: 400 }}"
                alt="{{ logo.alt | default: 'Media logo' | escape }}"
                loading="lazy"
                width="{{ logo.width }}"
                height="{{ logo.height }}"
              >
            </div>
          {% else %}
            <div class="ai-as-seen-on-logo-item-{{ ai_gen_id }}">
              <div class="ai-as-seen-on-logo-placeholder-{{ ai_gen_id }}">
                Add logo {{ i }}
              </div>
            </div>
          {% endif %}
        {% endfor %}
        {% for i in (1..10) %}
          {% assign logo_key = 'logo_' | append: i %}
          {% assign logo = block.settings[logo_key] %}
          {% if logo %}
            <div class="ai-as-seen-on-logo-item-{{ ai_gen_id }}">
              <img
                src="{{ logo | image_url: width: 400 }}"
                alt="{{ logo.alt | default: 'Media logo' | escape }}"
                loading="lazy"
                width="{{ logo.width }}"
                height="{{ logo.height }}"
              >
            </div>
          {% else %}
            <div class="ai-as-seen-on-logo-item-{{ ai_gen_id }}">
              <div class="ai-as-seen-on-logo-placeholder-{{ ai_gen_id }}">
                Add logo {{ i }}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</as-seen-on-{{ ai_gen_id }}>

<script>
  (function() {
    class AsSeenOn{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustMarqueeSpeed();
      }

      adjustMarqueeSpeed() {
        const marquee = this.querySelector('.ai-as-seen-on-marquee-{{ ai_gen_id }}');
        if (!marquee) return;

        const items = marquee.querySelectorAll('.ai-as-seen-on-logo-item-{{ ai_gen_id }}');
        if (items.length === 0) return;
      }
    }

    customElements.define('as-seen-on-{{ ai_gen_id }}', AsSeenOn{{ ai_gen_id }});
  })();
</script>

