    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "range",
      "id": "nav_font_size",
      "label": "Font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "nav_gap",
      "label": "Gap between logo and nav",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "nav_link_spacing",
      "label": "Space between links",
      "min": 15,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 18,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "label": "Space between icons",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1400
    },
    {
      "type": "range",
      "id": "header_padding",
      "label": "Vertical padding",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side padding",
      "min": 15,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Gold accent line"
    },
    {
      "type": "range",
      "id": "gold_line_height",
      "label": "Line height",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 3
    },
    {
      "type": "range",
      "id": "pulse_speed",
      "label": "Pulse speed",
      "min": 2,
      "max": 6,
      "step": 1,
      "unit": "s",
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Ester Flonaze header"
    }
  ]
}
{% endschema %}
