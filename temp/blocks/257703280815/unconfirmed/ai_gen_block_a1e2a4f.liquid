{% doc %}
  @prompt
    Build a complete "As Seen On" homepage section for a drag brand called Ester Flonaze. This is a full rebuild from scratch.
    
    EXACT TEXT:
    - Top line: "AS SEEN ON" 
    - Bottom line: "Granny's Been Around"
    
    EXACT TEXT STYLING:
    "AS SEEN ON": 
    - 14px, uppercase, letter-spacing: 4px, color: #9b59b6, no glow, clean sans-serif
    
    "Granny's Been Around":
    - Font: Playfair Display, imported from Google Fonts
    - Size: 72px
    - Weight: bold
    - Color: #ffffff
    - text-shadow: 0 0 20px rgba(212,175,55,0.9), 0 0 40px rgba(155,89,182,0.6), 0 0 60px rgba(212,175,55,0.4)
    
    BACKGROUND: linear-gradient(135deg, #1A1A2E 0%, #2a1f3d 100%)
    
    LOGO MARQUEE:
    - Infinite horizontal auto-scrolling marquee (CSS animation, seamless loop)
    - 9 editable image blocks in theme editor sidebar
    - Logos displayed in grayscale at 75% opacity by default
    - On hover: full color, 100% opacity, marquee pauses
    - Consistent height: 50px for all logos
    - Gold divider line (#D4AF37, 1px) above the logo marquee row
    
    LAYOUT:
    - "AS SEEN ON" centered at top
    - "Granny's Been Around" centered below it
    - Gold divider line
    - Logo marquee below divider
    - Generous padding top and bottom (60px)
    
    MOBILE: touch-scroll on mobile, smooth
    
    Import Playfair Display from Google Fonts at the top of the file.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

{% style %}
  .ai-as-seen-on-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, #1A1A2E 0%, #2a1f3d 100%);
    padding: 60px 20px;
    overflow: hidden;
  }

  .ai-as-seen-on-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-as-seen-on-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 50px;
  }

  .ai-as-seen-on-eyebrow-{{ ai_gen_id }} {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: #9b59b6;
    margin: 0 0 20px 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  }

  .ai-as-seen-on-title-{{ ai_gen_id }} {
    font-family: 'Playfair Display', serif;
    font-size: 72px;
    font-weight: bold;
    color: #ffffff;
    text-shadow: 0 0 20px rgba(212,175,55,0.9), 0 0 40px rgba(155,89,182,0.6), 0 0 60px rgba(212,175,55,0.4);
    margin: 0;
    line-height: 1.2;
  }

  .ai-as-seen-on-divider-{{ ai_gen_id }} {
    width: 100%;
    height: 1px;
    background-color: #D4AF37;
    margin-bottom: 40px;
  }

  .ai-as-seen-on-marquee-wrapper-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .ai-as-seen-on-marquee-{{ ai_gen_id }} {
    display: flex;
    gap: 60px;
    animation: ai-as-seen-on-scroll-{{ ai_gen_id }} 30s linear infinite;
    will-change: transform;
  }

  .ai-as-seen-on-marquee-wrapper-{{ ai_gen_id }}:hover .ai-as-seen-on-marquee-{{ ai_gen_id }} {
    animation-play-state: paused;
  }

  .ai-as-seen-on-logo-{{ ai_gen_id }} {
    flex-shrink: 0;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-as-seen-on-logo-{{ ai_gen_id }} img {
    height: 50px;
    width: auto;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.75;
    transition: all 0.3s ease;
  }

  .ai-as-seen-on-logo-{{ ai_gen_id }}:hover img {
    filter: grayscale(0%);
    opacity: 1;
  }

  .ai-as-seen-on-logo-placeholder-{{ ai_gen_id }} {
    width: 150px;
    height: 50px;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.3);
    font-size: 12px;
    text-align: center;
    padding: 10px;
  }

  @keyframes ai-as-seen-on-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 768px) {
    .ai-as-seen-on-{{ ai_gen_id }} {
      padding: 40px 20px;
    }

    .ai-as-seen-on-title-{{ ai_gen_id }} {
      font-size: 42px;
    }

    .ai-as-seen-on-eyebrow-{{ ai_gen_id }} {
      font-size: 12px;
      letter-spacing: 3px;
    }

    .ai-as-seen-on-marquee-wrapper-{{ ai_gen_id }} {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .ai-as-seen-on-marquee-{{ ai_gen_id }} {
      animation: none;
    }

    .ai-as-seen-on-marquee-wrapper-{{ ai_gen_id }}:hover .ai-as-seen-on-marquee-{{ ai_gen_id }} {
      animation: none;
    }
  }
{% endstyle %}

<as-seen-on-{{ ai_gen_id }} class="ai-as-seen-on-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-as-seen-on-container-{{ ai_gen_id }}">
    <div class="ai-as-seen-on-header-{{ ai_gen_id }}">
      <p class="ai-as-seen-on-eyebrow-{{ ai_gen_id }}">AS SEEN ON</p>
      <h2 class="ai-as-seen-on-title-{{ ai_gen_id }}">Granny's Been Around</h2>
    </div>

    <div class="ai-as-seen-on-divider-{{ ai_gen_id }}"></div>

    <div class="ai-as-seen-on-marquee-wrapper-{{ ai_gen_id }}">
      <div class="ai-as-seen-on-marquee-{{ ai_gen_id }}">
        {% for i in (1..9) %}
          {% assign logo_key = 'logo_' | append: i %}
          {% assign logo = block.settings[logo_key] %}
          
          <div class="ai-as-seen-on-logo-{{ ai_gen_id }}">
            {% if logo %}
              <img
                src="{{ logo | image_url: width: 300 }}"
                alt="Logo {{ i }}"
                loading="lazy"
                width="150"
                height="50"
              >
            {% else %}
              <div class="ai-as-seen-on-logo-placeholder-{{ ai_gen_id }}">
                Logo {{ i }}
              </div>
            {% endif %}
          </div>
        {% endfor %}

        {% for i in (1..9) %}
          {% assign logo_key = 'logo_' | append: i %}
          {% assign logo = block.settings[logo_key] %}
          
          <div class="ai-as-seen-on-logo-{{ ai_gen_id }}">
            {% if logo %}
              <img
                src="{{ logo | image_url: width: 300 }}"
                alt="Logo {{ i }}"
                loading="lazy"
                width="150"
                height="50"
              >
            {% else %}
              <div class="ai-as-seen-on-logo-placeholder-{{ ai_gen_id }}">
                Logo {{ i }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</as-seen-on-{{ ai_gen_id }}>

<script>
  (function() {
    class AsSeenOn{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupMarquee();
      }

      setupMarquee() {
        const marquee = this.querySelector('.ai-as-seen-on-marquee-{{ ai_gen_id }}');
        if (!marquee) return;

        const logos = marquee.querySelectorAll('.ai-as-seen-on-logo-{{ ai_gen_id }}');
        if (logos.length === 0) return;

        const totalWidth = Array.from(logos).slice(0, 9).reduce((sum, logo) => {
          return sum + logo.offsetWidth + 60;
        }, 0);

        marquee.style.width = (totalWidth * 2) + 'px';
      }
    }

    customElements.define('as-seen-on-{{ ai_gen_id }}', AsSeenOn{{ ai_gen_id }});
  })();
</script>

