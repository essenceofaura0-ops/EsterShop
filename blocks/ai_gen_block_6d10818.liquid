  "name": "Ester Flonaze header",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Ester Flonaze"
    },
    {
      "type": "range",
      "id": "logo_size",
      "label": "Logo size",
      "min": 20,
