{% doc %}
  @prompt
    Create an "As Seen On" press logo section with a heading that says "Granny's Been Around" and a subheading label "AS SEEN ON" in small uppercase pink/purple text. The section should display a horizontal row of 9 logo image slots that the merchant can fill in themselves via the theme editor. The section should have a dark navy/dark blue background to match the store's existing style. Each logo slot should be customizable in the theme editor sidebar. The logos should be evenly spaced and centered on the page.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-press-logos-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-press-logos-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-press-logos-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-press-logos-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0 0 {{ block.settings.label_spacing }}px;
    font-weight: 600;
  }

  .ai-press-logos-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: 700;
  }

  .ai-press-logos-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
    gap: {{ block.settings.logo_spacing }}px;
    align-items: center;
    justify-items: center;
  }

  .ai-press-logos-item-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
  }

  .ai-press-logos-item-{{ ai_gen_id }} img {
    max-width: {{ block.settings.logo_max_width }}px;
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: {{ block.settings.logo_filter }};
    opacity: {{ block.settings.logo_opacity }};
    transition: opacity 0.3s ease;
  }

  .ai-press-logos-item-{{ ai_gen_id }} img:hover {
    opacity: 1;
  }

  .ai-press-logos-placeholder-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.logo_max_width }}px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-press-logos-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-press-logos-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
      gap: {{ block.settings.logo_spacing | divided_by: 2 }}px;
    }

    .ai-press-logos-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-press-logos-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-press-logos-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-press-logos-container-{{ ai_gen_id }}">
    <div class="ai-press-logos-header-{{ ai_gen_id }}">
      {% if block.settings.label != blank %}
        <p class="ai-press-logos-label-{{ ai_gen_id }}">{{ block.settings.label }}</p>
      {% endif %}
      {% if block.settings.heading != blank %}
        <h2 class="ai-press-logos-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="ai-press-logos-grid-{{ ai_gen_id }}">
      {% for i in (1..9) %}
        {% liquid
          assign logo_key = 'logo_' | append: i
          assign logo = block.settings[logo_key]
        %}
        <div class="ai-press-logos-item-{{ ai_gen_id }}">
          {% if logo != blank %}
            <img
              src="{{ logo | image_url: width: 400 }}"
              alt="{{ logo.alt | escape }}"
              loading="lazy"
              width="{{ logo.width }}"
              height="{{ logo.height }}"
            >
          {% else %}
            <div class="ai-press-logos-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

